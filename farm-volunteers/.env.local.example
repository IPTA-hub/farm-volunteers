# Supabase — from your Supabase project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Resend — from resend.com > API Keys
RESEND_API_KEY=re_your_key
RESEND_FROM_EMAIL=volunteers@yourfarm.com

# Twilio — from console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# Internal secret to protect notification endpoints
NOTIFICATIONS_SECRET=pick-a-long-random-string
